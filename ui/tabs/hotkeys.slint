// Hotkey configuration tab
import { VerticalBox, ScrollView, Button, CheckBox, HorizontalBox, GroupBox, LineEdit, ComboBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";

component HotkeyRecorder {
    in property <string> label;
    in property <string> binding-text;
    callback record-clicked();
    
    HorizontalBox {
        Text {
            text: root.label;
            vertical-alignment: center;
            width: 150px;
            color: Theme.text-primary;
        }
        
        Button {
            text: root.binding-text == "" ? "Click to Set" : root.binding-text;
            width: 200px;
            clicked => {
                root.record-clicked();
            }
        }
    }
}

export component HotkeysTab {
    // Properties
    in-out property <string> input-device;
    in-out property <string> hotkey-backend: "X11"; // "X11" or "Evdev"
    in-out property <string> hotkey-toggle-preview;
    in-out property <string> hotkey-toggle-skip;
    in-out property <string> hotkey-profile-switch;
    in-out property <string> hotkey-cycle-forward;
    in-out property <string> hotkey-cycle-backward;
    in-out property <bool> hotkey-require-eve-focus;
    
    callback update-binding(string); // ID of the binding being updated
    
    ScrollView {
        VerticalBox {
            spacing: Theme.spacing-large;
            alignment: start;

            Text {
                text: "Hotkey Settings";
                font-size: Theme.font-size-header;
                font-weight: 700;
                color: Theme.text-primary;
            }
             
            // Backend Settings
            GroupBox {
                title: "Input Backend";
                VerticalBox {
                    spacing: 10px;
                    HorizontalBox {
                        Text {
                            text: "Input Device Path:";
                            vertical-alignment: center;
                            width: 150px;
                        }
                        LineEdit {
                            text: root.input-device;
                            enabled: false; // Read-only for now, detection is auto
                        }
                    }
                    
                    HorizontalBox {
                        Text {
                            text: "Backend:";
                            vertical-alignment: center;
                            width: 150px;
                        }
                        // TODO: Bind to backend selection property
                        ComboBox {
                            model: ["X11", "Evdev"];
                            current-index: 0; 
                            enabled: true;
                        }
                    }
                }
            }
             
            // Global Hotkeys
            GroupBox {
                title: "Global Hotkeys";
                VerticalBox {
                    spacing: 10px;
                    
                    CheckBox {
                        text: "Require EVE Client Focus for Hotkeys";
                        // Note: Property needs to be added to root first
                        checked <=> root.hotkey-require-eve-focus;
                    }
                    
                    HotkeyRecorder {
                        label: "Cycle Forward:";
                        binding-text: root.hotkey-cycle-forward;
                        record-clicked => { root.update-binding("cycle_forward"); }
                    }
                    
                    HotkeyRecorder {
                        label: "Cycle Backward:";
                        binding-text: root.hotkey-cycle-backward;
                        record-clicked => { root.update-binding("cycle_backward"); }
                    }
                    
                    HotkeyRecorder {
                        label: "Toggle Previews:";
                        binding-text: root.hotkey-toggle-preview;
                        record-clicked => { root.update-binding("toggle_previews"); }
                    }
                    
                    HotkeyRecorder {
                        label: "Toggle Ignore/Skip:";
                        binding-text: root.hotkey-toggle-skip;
                        record-clicked => { root.update-binding("toggle_skip"); }
                    }
                    
                    HotkeyRecorder {
                        label: "Next Profile:";
                        binding-text: root.hotkey-profile-switch;
                        record-clicked => { root.update-binding("profile_switch"); }
                    }
                }
            }
             
            Text {
                text: "Note: Hotkey recording logic to be implemented on backend.";
                color: #888;
                font-size: 12px;
            }
        }
    }
}
