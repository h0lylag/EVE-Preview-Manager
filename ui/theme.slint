export global Theme {
    // Color Palette (Dark Mode - EVE inspired)
    in property <color> background: #1a1a1a;
    in property <color> surface: #2d2d2d;
    in property <color> surface-hover: #3d3d3d;
    in property <color> primary: #007bff; // EVE Blue-ish
    in property <color> primary-hover: #3395ff;
    in property <color> danger: #dc3545;
    in property <color> warning: #ffc107;
    in property <color> success: #28a745;
    in property <color> text-primary: #ffffff;
    in property <color> text-secondary: #b0b0b0;
    in property <color> border: #404040;

    // Typography
    in property <length> font-size-small: 12px;
    in property <length> font-size-normal: 14px;
    in property <length> font-size-large: 16px;
    in property <length> font-size-header: 20px;

    // Spacing
    in property <length> spacing-small: 4px;
    in property <length> spacing-normal: 8px;
    in property <length> spacing-large: 16px;
    in property <length> padding-normal: 10px;
    
    // Components
    in property <length> border-radius: 4px;
}
