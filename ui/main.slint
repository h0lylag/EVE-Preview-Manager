// Main window component for EVE Preview Manager
import { Button, VerticalBox, HorizontalBox, TabWidget, ComboBox, LineEdit } from "std-widgets.slint";
import { ProfileDialogs } from "components/profile_dialogs.slint";
import { BehaviorTab } from "tabs/behavior.slint";
import { TabButton } from "components/tab_button.slint";
import { HotkeyModal } from "components/hotkey_modal.slint";
import { AppearanceTab } from "tabs/appearance.slint";
import { HotkeysTab } from "tabs/hotkeys.slint";
import { CharactersTab } from "tabs/characters.slint";
import { SourcesTab } from "tabs/sources.slint";
import { Theme } from "theme.slint";

export component MainWindow inherits Window {
    title: "EVE Preview Manager";
    preferred-width: 800px;
    preferred-height: 600px;
    background: Theme.background;
    
    // Callbacks for window lifecycle
    callback minimize-to-tray();
    callback exit-app();
    
    // Daemon status properties
    in property <string> daemon-status: "Stopped";
    in property <color> daemon-status-color: Theme.danger; // Default stop color
    in property <int> daemon-pid: 0;
    in property <string> status-message: "";
    in property <color> status-message-color: Theme.text-primary;
    
    // Profile management properties
    in-out property <int> selected-profile-index: 0;
    in property <[string]> profile-names: [];
    in property <[string]> profile-descriptions: [];
    
    // Profile management callbacks
    callback load-profile(int);
    callback new-profile();
    callback duplicate-profile();
    callback edit-profile();
    callback delete-profile();
    
    // Save/Discard callbacks
    callback save-config();
    callback discard-changes();
    
    // Config status
    in property <bool> has-unsaved-changes: false;
    in property <string> config-status-message: "";
    in property <color> config-status-color: #ffffff;
    
    // Profile Dialog Properties (bound to Rust)
    in-out property <bool> show-new-profile-dialog: false;
    in-out property <bool> show-duplicate-profile-dialog: false;
    in-out property <bool> show-edit-profile-dialog: false;
    in-out property <bool> show-delete-profile-confirm: false;
    in-out property <string> edit-profile-name: "";
    in-out property <string> edit-profile-desc: "";
    
    callback create-profile(string, string);
    callback duplicate-profile-confirmed(string, string);
    callback edit-profile-confirmed(string, string);
    callback delete-profile-confirmed();
    callback cancel-profile-dialog();

    // Source Properties (bound to Rust)
    in property <[StandardListViewItem]> source-model;
    in-out property <int> source-selected-index: -1;
    in-out property <string> source-edit-alias: "";
    in-out property <string> source-edit-title-pattern: "";
    in-out property <string> source-edit-class-pattern: "";
    in-out property <string> source-edit-border-color: "";
    in-out property <int> source-edit-border-size: 0;
    callback source-selected(int);
    callback save-source();
    callback add-source();
    callback remove-source();

    // Character Properties (bound to Rust)
    in property <[StandardListViewItem]> character-model;
    in-out property <int> character-selected-index: -1;
    in-out property <string> character-edit-name: "";
    in-out property <int> character-edit-width: 0;
    in-out property <int> character-edit-height: 0;
    in-out property <bool> character-edit-disabled: false;
    callback character-selected(int);
    callback save-character();
    callback move-character-up(int);
    callback move-character-down(int);

    // Hotkey Properties (bound to Rust)
    in-out property <string> hotkey-input-device: "Auto";
    in-out property <string> hotkey-backend: "X11";
    in-out property <string> hotkey-toggle-preview: "None";
    in-out property <string> hotkey-toggle-skip: "None";
    in-out property <string> hotkey-profile-switch: "None";
    in-out property <string> hotkey-cycle-forward: "None";
    // in-out property <string> hotkey-cycle-forward: "None"; // Removed duplicate
    in-out property <string> hotkey-cycle-backward: "None";
    in-out property <bool> hotkey-require-eve-focus: false;

    
    // Behavior Properties (bound to Rust)
    in-out property <bool> behavior-auto-save-position: true;
    in-out property <int> behavior-snap-threshold: 20;
    in-out property <bool> behavior-hide-not-focused: false;
    in-out property <bool> behavior-preserve-position: true;
    in-out property <bool> behavior-minimize-on-switch: false;
    // in-out property <bool> behavior-minimize-on-switch: false; // Removed duplicate
    // in-out property <bool> behavior-require-eve-focus: false; // Moved to Hotkeys properties
    in-out property <bool> behavior-inherit-position: false;
    in-out property <bool> behavior-cycle-logged-out: false;
    in-out property <bool> behavior-reset-index: false;

    // Appearance Properties (bound to Rust)
    in-out property <bool> appearance-thumbnail-enabled: true;
    in-out property <float> appearance-thumbnail-opacity: 100.0;
    in-out property <bool> appearance-active-border-enabled: true;
    in-out property <int> appearance-active-border-size: 2;
    in-out property <string> appearance-active-border-color: "#00FF00";
    in-out property <bool> appearance-inactive-border-enabled: false;
    in-out property <int> appearance-inactive-border-size: 2;
    in-out property <string> appearance-inactive-border-color: "#666666";
    in-out property <bool> appearance-show-overlay: false;
    // Thumbnail Text
    in-out property <int> appearance-thumbnail-text-size: 14;
    in-out property <string> appearance-thumbnail-text-color: "#FFFFFF";
    in-out property <int> appearance-thumbnail-text-x: 0;
    in-out property <int> appearance-thumbnail-text-y: 0;
    in-out property <string> appearance-thumbnail-text-font: "";
    
    // Backup Properties (bound to Rust)
    in-out property <bool> backup-enabled: true;
    in-out property <int> backup-interval: 1;
    in-out property <int> backup-retention: 30;
    callback create-backup();
    callback restore-backup();
    callback delete-backup();

    // Tab selection
    in-out property <int> active-tab: 0;
    
    // Hotkey Binding State
    property <bool> is-binding: false;
    property <string> active-binding-id;
    
    // Callbacks
    callback update-binding(string); // Relay from tab to backend
    callback cancel-binding();       // Cancel request from modal
    callback apply-binding(string, string, string); // id, text, modifiers

    VerticalBox {
        padding: 0px;
        spacing: Theme.spacing-normal;
        
        // Header: Daemon Status + Tabs
        HorizontalBox {
            spacing: Theme.spacing-normal;
            
            // Left: Daemon Status
            HorizontalBox {
                spacing: Theme.spacing-small;
                
                Text {
                    text: daemon-status;
                    color: daemon-status-color;
                    font-weight: 700;
                    font-size: Theme.font-size-large;
                    vertical-alignment: center;
                }
                
                if daemon-pid > 0: Text {
                    text: "(PID: " + daemon-pid + ")";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-small;
                    vertical-alignment: center;
                }
                
                if status-message != "": Text {
                    text: status-message;
                    color: status-message-color;
                    vertical-alignment: center;
                }
            }
            
            Rectangle { 
                // Spacer
                horizontal-stretch: 1;
            }
            
            // Right: Tab Navigation
            HorizontalBox {
                spacing: Theme.spacing-small;
                
                TabButton {
                    text: "Behavior";
                    active: active-tab == 0;
                    clicked => { active-tab = 0; }
                }
                
                TabButton {
                    text: "Hotkeys";
                    active: active-tab == 1;
                    clicked => { active-tab = 1; }
                }
                
                TabButton {
                    text: "Appearance";
                    active: active-tab == 2;
                    clicked => { active-tab = 2; }
                }
                
                TabButton {
                    text: "Characters";
                    active: active-tab == 3;
                    clicked => { active-tab = 3; }
                }
                
                TabButton {
                    text: "Sources";
                    active: active-tab == 4;
                    clicked => { active-tab = 4; }
                }
            }
        }
        
        Rectangle {
            height: 1px;
            background: Theme.border;
        }
        
        // Control Bar: Profile Selector + Save/Discard
        HorizontalBox {
            spacing: Theme.spacing-normal;
            
            ComboBox {
                model: root.profile-names;
                current-index <=> root.selected-profile-index;
                width: 250px;
                selected(val) => {
                    // Logic handled via index change binding or callback if needed
                    root.load-profile(root.selected-profile-index);
                }
            }
            
            Rectangle { 
                horizontal-stretch: 1;
            }
            
            Button {
                text: "💾 Save & Apply";
                primary: true;
                clicked => { save-config(); }
            }
            
            Button {
                text: "✖ Discard Changes";
                clicked => { discard-changes(); }
            }
        }
        
        // Profile Actions + Config Status
        HorizontalBox {
            spacing: Theme.spacing-small;
            
            Button {
                text: "➕ New";
                clicked => { new-profile(); }
            }
            
            Button {
                text: "📋 Duplicate";
                clicked => { duplicate-profile(); }
            }
            
            Button {
                text: "✏ Edit";
                clicked => { edit-profile(); }
            }
            
            Button {
                text: "🗑 Delete";
                clicked => { delete-profile(); }
            }
            
            Rectangle { 
                horizontal-stretch: 1;
            }
            
            if config-status-message != "": Text {
                text: config-status-message;
                color: config-status-color;
                vertical-alignment: center;
            }
            
            if has-unsaved-changes && config-status-message == "": Text {
                text: "Unsaved changes";
                color: Theme.warning;
                vertical-alignment: center;
            }
        }
        
        Rectangle {
            height: 1px;
            background: Theme.border;
        }
        
        // Tab Content
        if active-tab == 0: BehaviorTab {
            auto-save-position <=> root.behavior-auto-save-position;
            snap-threshold <=> root.behavior-snap-threshold;
            hide-when-not-focused <=> root.behavior-hide-not-focused;
            preserve-position <=> root.behavior-preserve-position;
            minimize-on-switch <=> root.behavior-minimize-on-switch;
            // require-eve-focus <=> root.behavior-require-eve-focus;
            inherit-position <=> root.behavior-inherit-position;
            cycle-logged-out <=> root.behavior-cycle-logged-out;
            reset-index <=> root.behavior-reset-index;
            
            // Backup
            backup-enabled <=> root.backup-enabled;
            backup-interval <=> root.backup-interval;
            backup-retention <=> root.backup-retention;
            create-backup => { root.create-backup(); }
            restore-backup => { root.restore-backup(); }
            delete-backup => { root.delete-backup(); }
        }
        
        if active-tab == 1: HotkeysTab {
            input-device <=> root.hotkey-input-device;
            hotkey-backend <=> root.hotkey-backend;
            hotkey-toggle-preview <=> root.hotkey-toggle-preview;
            hotkey-toggle-skip <=> root.hotkey-toggle-skip;
            hotkey-profile-switch <=> root.hotkey-profile-switch;
            hotkey-cycle-forward: root.hotkey-cycle-forward;
            hotkey-cycle-backward: root.hotkey-cycle-backward;
            hotkey-require-eve-focus <=> root.hotkey-require-eve-focus;
            
            update-binding(id) => {
                root.is-binding = true;
                root.active-binding-id = id;
                root.update-binding(id); // Notify backend
                modal.request-focus();
            }
        }
        
        if active-tab == 2: AppearanceTab {
            thumbnail-enabled <=> root.appearance-thumbnail-enabled;
            thumbnail-opacity <=> root.appearance-thumbnail-opacity;
            active-border-enabled <=> root.appearance-active-border-enabled;
            active-border-size <=> root.appearance-active-border-size;
            active-border-color <=> root.appearance-active-border-color;
            inactive-border-enabled <=> root.appearance-inactive-border-enabled;
            inactive-border-size <=> root.appearance-inactive-border-size;
            inactive-border-color <=> root.appearance-inactive-border-color;
            show-overlay <=> root.appearance-show-overlay;
            thumbnail-text-size <=> root.appearance-thumbnail-text-size;
            thumbnail-text-color <=> root.appearance-thumbnail-text-color;
            thumbnail-text-x <=> root.appearance-thumbnail-text-x;
            thumbnail-text-y <=> root.appearance-thumbnail-text-y;
            thumbnail-text-font <=> root.appearance-thumbnail-text-font;
        }
        
        if active-tab == 3: CharactersTab {
            character-model: root.character-model;
            selected-index <=> root.character-selected-index;
            edit-name <=> root.character-edit-name;
            edit-width <=> root.character-edit-width;
            edit-height <=> root.character-edit-height;
            edit-disabled <=> root.character-edit-disabled;
            selection-changed(idx) => { root.character-selected(idx); }
            save-character => { root.save-character(); }
            move-character-up(idx) => { root.move-character-up(idx); }
            move-character-down(idx) => { root.move-character-down(idx); }
        }
        
        if active-tab == 4: SourcesTab {
            source-model: root.source-model;
            selected-index <=> root.source-selected-index;
            edit-alias <=> root.source-edit-alias;
            edit-title-pattern <=> root.source-edit-title-pattern;
            edit-class-pattern <=> root.source-edit-class-pattern;
            edit-border-color <=> root.source-edit-border-color;
            edit-border-size <=> root.source-edit-border-size;
            
            selection-changed(idx) => { root.source-selected(idx); }
            save-source => { root.save-source(); }
            add-source => { root.add-source(); }
            remove-source => { root.remove-source(); }
        }
    }
    
    ProfileDialogs {
        show-new-dialog <=> root.show-new-profile-dialog;
        show-duplicate-dialog <=> root.show-duplicate-profile-dialog;
        show-edit-dialog <=> root.show-edit-profile-dialog;
        show-delete-confirm <=> root.show-delete-profile-confirm;
        
        edit-profile-name <=> root.edit-profile-name;
        edit-profile-desc <=> root.edit-profile-desc;
        
        create-profile(name, desc) => { root.create-profile(name, desc); }
        duplicate-profile-confirmed(name, desc) => { root.duplicate-profile-confirmed(name, desc); }
        edit-profile-confirmed(name, desc) => { root.edit-profile-confirmed(name, desc); }
        delete-profile-confirmed => { root.delete-profile-confirmed(); }
        cancel-dialog => { root.cancel-profile-dialog(); }
    }

    // Modal Overlay (Must be last to be on top)
    modal := HotkeyModal {
        show: root.is-binding;
        binding-name: root.active-binding-id;
        
        cancel => {
            root.is-binding = false;
            root.cancel-binding();
        }
        
        
        // If we decide to handle keys in UI later:
        key-pressed(text, modifiers) => {
            root.is-binding = false;
            root.apply-binding(root.active-binding-id, text, modifiers);
        }
    }
}
